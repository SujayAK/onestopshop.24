# Environment Configuration Template
# Copy this to .env file and fill in your actual values

# Razorpay API Keys (Get from https://dashboard.razorpay.com/app/keys)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key_here

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Frontend Configuration
VITE_STORE_NAME=OneStop Shop 24
VITE_STORE_EMAIL=support@onestopshop24.com
VITE_SUPPORT_PHONE=+1 (234) 567-890

# Environment
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_PAYMENT_HISTORY=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=false
VITE_ENABLE_SMS_NOTIFICATIONS=false

# Payment Configuration
VITE_CURRENCY=INR
VITE_TAX_RATE=0.1
VITE_SHIPPING_COST=0

# Logging
VITE_LOG_LEVEL=info
