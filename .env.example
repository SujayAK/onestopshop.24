# Environment Configuration Template
# Copy this file to .env and update values for your environment.

# Cloudflare API and image delivery
VITE_CLOUDFLARE_API_BASE_URL=https://api.onestopshop24.in
VITE_CLOUDFLARE_IMAGE_BASE_URL=https://api.onestopshop24.in
VITE_CLOUDFLARE_DEV_MODE=true

# Image optimization
VITE_IMAGE_SERVICE=cloudflare
VITE_CLOUDFLARE_DELIVERY_DOMAIN=https://onestopshop24.in
VITE_IMAGE_QUALITY=78

# Frontend store info
VITE_STORE_NAME=OneStop Shop 24
VITE_STORE_EMAIL=contact.onestopshop24@gmail.com
VITE_SUPPORT_PHONE=+1 (234) 567-890

# Dummy/test payment key used by frontend helper
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
